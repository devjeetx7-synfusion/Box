rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if request is by an authenticated admin
    function isAdmin() {
      return request.auth != null && (request.auth.token.admin == true || request.auth.token.role == 'admin');
    }

    // Rules for Device Document
    match /devices/{deviceId} {
      // Admin can read and write everything on any device
      allow read, write: if isAdmin();

      // Client User app rules for its own device document
      allow read: if true;
      allow write: if request.auth == null
                   && (
                     // Restrict client writes to only allowed summary and sync tracking fields
                     request.resource.data.diff(resource.data).affectedKeys()
                     .hasOnly(['heartbeatAt', 'timestamp', 'lastSyncTime', 'lastMediaSyncTime', 'lastMediaScanAt', 'lastMediaSyncAt',
                               'syncRequestedAt', 'forceFullSyncRequestedAt', 'syncStatus', 'lastError', 'lastMediaError', 'lastMediaErrorStage',
                               'contactCount', 'smsCount', 'callCount', 'notificationCount', 'mediaDiscoveredCount', 'mediaUploadedCount', 'mediaFailedCount',
                               'sim1Carrier', 'sim2Carrier', 'sim1Number', 'sim2Number', 'sim1SubscriptionId', 'sim2SubscriptionId', 'sim1Ready', 'sim2Ready',
                               'ownerName', 'ownerPhone', 'ownerEmail', 'ownerCity', 'ownerState', 'profileUpdatedAt', 'profileRevision', 'firebaseWriteVerifiedAt'])
                   );
    }

    // Rules for Profile details document
    match /devices/{deviceId}/profile/details {
      allow read: if isAdmin() || request.auth == null;
      allow write: if request.auth == null
                   && request.resource.data.fullName is string && request.resource.data.fullName.size() >= 2 && request.resource.data.fullName.size() <= 80
                   && request.resource.data.primaryPhone is string && request.resource.data.primaryPhone.size() >= 7 && request.resource.data.primaryPhone.size() <= 15;
    }

    // Rules for subcollections (contacts, sms, calllogs, notifications, media, commands)
    match /devices/{deviceId}/{collection}/{doc} {
      allow read: if isAdmin() || (request.auth == null && collection != 'commands');
      allow write: if request.auth == null && collection != 'commands';
    }
  }
}
